#!/usr/bin/env python

from argparse import ArgumentParser

if __name__ == "__main__":
    parser = ArgumentParser(prog="civetpy")
    parser.add_argument("civet_output", type=str, nargs=1, help="The path to the quality control csv file outputed by CIVET")
    parser.add_argument("user_ratings", type=str, nargs=1, help="The path to the csv file containing user quality control ratings")
    args = parser.parse_args()
    
    civet_output, user_ratings = args.civet_output[0], args.user_ratings[0]

    for path in [civet_output, user_ratings]:
        if path.split(".")[-1] != "csv":
            raise ValueError(f"The file '{path}' must be in csv format")
    
    


