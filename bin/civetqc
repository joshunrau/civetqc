#!/usr/bin/env python
#
# TO-DO 
# finish merge with NA
from civetqc.data_classes import CivetOutput, UserRatings, CivetData
from civetqc.parse_args import parse_args
import sys


def main() -> None:
    args = parse_args(sys.argv[1:])
    dataset = CivetData(CivetOutput(args.civet_output[0]), UserRatings(args.user_ratings[0]), drop_na=True)
    dataset.test_knn(range(1, 10))

if __name__ == "__main__":
    main()

