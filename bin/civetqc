#!/usr/bin/env python

from civetqc.arguments import Arguments
from civetqc.dataset import Dataset
from civetqc.modeler import Modeler
import sys


def main() -> None:
    
    cmd = Arguments(sys.argv[1:])
    cmd.check_args()

    model = Modeler(cmd.args.civet_output, cmd.args.user_ratings, cmd.args.cutoff)
    print(model)


if __name__ == "__main__":
    main()
