#!/usr/bin/env python

from civetqc.arguments import Arguments
from civetqc.dataset import Dataset
from civetqc.model import Model
import sys


def main() -> None:
    
    cmd = Arguments(sys.argv[1:])
    cmd.check_args()

    dataset = Dataset(cmd.args.civet_output, cmd.args.user_ratings, cmd.args.cutoff)
    model = Model(dataset)
    print(model)


if __name__ == "__main__":
    main()
