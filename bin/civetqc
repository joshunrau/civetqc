#!/usr/bin/env python

from civetqc.arguments import Arguments
from civetqc.modeler import Modeler
import sys


def main() -> None:
    
    cmd = Arguments(sys.argv[1:])

    if cmd.args.verbose:
        vprint = print
        vprint("Using verbose output...")
    else:
        vprint = lambda *a, **k: None
    
    vprint("Creating Modeler...")
    model = Modeler(cmd.args.civet_output, cmd.args.user_ratings, cmd.args.cutoff)
    vprint("Done!")

if __name__ == "__main__":
    main()
