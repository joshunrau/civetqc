from civetqc.dataset import CivetOutput, UserRatings, MergedDataset
from civetqc.parse_args import parse_args
import sys


def main() -> None:
    args = parse_args(sys.argv[1:])
    merged_dataset = MergedDataset(CivetOutput(args.civet_output[0]), UserRatings(args.user_ratings[0]))
    print(merged_dataset.data)

if __name__ == "__main__":
    main()

