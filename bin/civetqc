#!/usr/bin/env python
#
# TO-DO 
# finish merge with NA
# take output dir as argument
# validate input for output dir
from argparse import ArgumentParser
from civetqc import *
from civetqc.utils import check_unique
import os
import pandas as pd

IDVAR = "ID"
QCVAR = "QC"


if __name__ == "__main__":

    # Specify arguments taken from command line
    parser = ArgumentParser(prog="civetqc")
    parser.add_argument("civet_output", type=str, nargs=1, help="The path to the quality control csv file outputed by CIVET")
    parser.add_argument("user_ratings", type=str, nargs=1, help="The path to the csv file containing user quality control ratings")
    parser.add_argument("-o", type=str, required=False, nargs=1, help="The path to directory where files should be outputted (default is home directory)")
    args = parser.parse_args()

    # Import civet qc data 
    civet_output = import_dataset(args.civet_output[0])
    
    # Import user ratings and coerce all non-numeric values to NA
    user_ratings = import_dataset(args.user_ratings[0], [IDVAR, QCVAR])
    user_ratings[QCVAR] = pd.to_numeric(user_ratings[QCVAR], errors='coerce')

    # Make sure all ID variable values are unique
    if not check_unique(civet_output[IDVAR]):
        raise AssertionError("Non-unique values for ID variable in CIVET QC output")
    if not check_unique(user_ratings[IDVAR]):
        raise ValueError("Non-unique values for ID variable in QC ratings file")

    # Combine dataframes
    df = pd.merge(civet_output, user_ratings, on='ID')

    # Output directory
    output_dir = os.path.expanduser('~')
    
    # Write csv file for documentation
    os.mkdir(os.path.join(output_dir, "civetqc"))
    df.to_csv(path_or_buf = os.path.join(output_dir, "civetqc", "df.csv'"))

