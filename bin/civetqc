#!/usr/bin/env python

from scipy.sparse import data
from civetqc.parser import parse_args
from civetqc.dataset import Dataset
import sys

from sklearn.neighbors import KNeighborsClassifier
from sklearn.metrics import precision_score
import numpy as np

def main() -> None:
    args = parse_args(sys.argv[1:])
    dataset = Dataset(args.civet_output, args.user_ratings, args.cutoff)
    knn = KNeighborsClassifier(n_neighbors=6)
    knn.fit(dataset.feat_train, dataset.targ_train)
    predicted_target = knn.predict(dataset.feat_test)
    precision = precision_score(dataset.targ_test, predicted_target, average='binary')
    print(f"Precision: {precision}")

    print_target_score(predicted_target, dataset.targ_test)


def print_target_score(predicted, actual):
    print("Test set score: {:.2f}".format(np.mean(predicted == actual)))
    

if __name__ == "__main__":
    main()
