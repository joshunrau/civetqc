#!/usr/bin/env python
# civetqc txt2csv /Users/joshua/Developer/civetqc/data/studies/TOPSY/raw /Users/joshua

import argparse
import civetqc.txt_to_csv as txt_to_csv 
import sys


def main():

    parser = argparse.ArgumentParser(prog="civetqc")
    subparsers = parser.add_subparsers(title='subcommands', description='valid subcommands', help='additional help')

    # create the parser for the 'txt_to_csv' command
    txt2csv = subparsers.add_parser("txt2csv", help="convert CIVET QC outputs from txt to csv")
    txt2csv.add_argument("input", help="path to directory containing txt files")
    txt2csv.add_argument("output", help="path to directory where csv should be outputted")
    txt2csv.set_defaults(func=txt_to_csv.parse_args)
    
    # get args from command line and pass to function
    args = parser.parse_args(sys.argv[1:])
    args.func(args)

if __name__ == "__main__":
    main()
